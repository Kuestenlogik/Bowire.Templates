<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Kuestenlogik.Bowire.* and everything else resolves from nuget.org once
       the public release is out. No GitHub Packages plumbing required. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
